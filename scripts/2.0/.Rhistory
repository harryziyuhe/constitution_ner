file = readLines("../../annotations.jsonl")
file
lines <- file[nzchar(trimws(file))]
lines
parsed <- lapply(lines, function(ln) {
tryCatch(fromJSON(ln), error = function(e) NULL)
})
parsed
parsed[[1]]
parsed[[2]]
parsed <- Filter(Negate(is.null), parsed)
# JSONL restore → dataset mode
n <- length(parsed)
texts <- vapply(parsed, function(r) as.character(r$text %||% ""), character(1L))
texts
ids   <- vapply(parsed, function(r) as.character(r$id %||% ""),  character(1L))
ids[1]
vector("list", n)
# helper: coerce one record's entities into a spans df
spans_from_record <- function(rec) {
ents <- rec$entities %||% rec$spans
if (is.null(ents) || !length(ents)) return(make_empty_spans())
if (is.data.frame(ents)) {
df <- ents
} else {
df <- as.data.frame(do.call(rbind, lapply(ents, as.data.frame)))
}
if (!("label" %in% names(df)) && ("type" %in% names(df))) df$label <- df$type
df$start <- as.integer(df$start)
df$end   <- as.integer(df$end)
df$label <- as.character(df$label)
df <- df[, c("start", "end", "label")]
df[order(df$start), , drop = FALSE]
}
i <- 2
spans_i <- spans_from_record(parsed[[i]])
spans_i
